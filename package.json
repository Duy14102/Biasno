{
  "name": "biasno",
  "version": "1.0.0",
  "description": "Biasno - Learn piano with MIDI files (Synthesia-style)",
  "author": "Biasno",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true,force:true})\"",
    "package": "npm run clean && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "package:installer": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "@tonejs/piano": "^0.2.1",
    "events": "^3.3.0",
    "opensheetmusicdisplay": "^1.9.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "soundfont-player": "^0.12.0",
    "tone": "^14.7.77"
  },
  "devDependencies": {
    "@types/node": "^20.16.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^32.0.1",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.biasno.app",
    "npmRebuild": false,
    "productName": "Biasno",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Biasno",
      "icon": "resources/icon.ico",
      "signingHashAlgorithms": null,
      "forceCodeSigning": false
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ]
  }
}
